---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SpeedInsights } from '@vercel/speed-insights/astro';
import '../styles/global.css';

interface Props {
  titre:       string;
  description: string;
  image?:      string;
}

const {
  titre,
  description,
  image = '/og-default.jpg',
} = Astro.props;

const NOM_SITE      = 'BNZ Toitures';
const titreComplet  = titre === NOM_SITE ? titre : `${titre} | ${NOM_SITE}`;
const urlCanonique  = Astro.url.href;
const urlImage      = new URL(image, Astro.url).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={urlCanonique} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO principal -->
    <title>{titreComplet}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={urlCanonique} />
    <meta property="og:title"       content={titreComplet} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={urlImage} />
    <meta property="og:locale"      content="fr_FR" />
    <meta property="og:site_name"   content={NOM_SITE} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={titreComplet} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={urlImage} />

    <!-- Slot head : pour injecter des scripts/styles supplémentaires par page -->
    <slot name="head" />
  </head>

  <body class="bg-white text-ardoise-900 antialiased">
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
    <SpeedInsights />
  </body>
</html>
