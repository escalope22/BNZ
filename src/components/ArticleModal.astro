---
---

<div
  id="article-modal"
  class="fixed inset-0 z-200 hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-titre"
>
  <!-- Fond flouté -->
  <div id="modal-fond" class="absolute inset-0 bg-ardoise-950/75 backdrop-blur-md"></div>

  <!-- Panneau scrollable -->
  <div class="relative z-10 h-full overflow-y-auto py-8 px-4">
    <div class="bg-white rounded-2xl w-full max-w-3xl mx-auto shadow-2xl">

      <!-- En-tête sticky -->
      <div class="sticky top-0 bg-white/95 backdrop-blur-sm border-b border-slate-100 px-6 sm:px-8 py-4 flex items-center justify-between rounded-t-2xl z-10">
        <div id="modal-tags" class="flex flex-wrap gap-2"></div>
        <button
          id="modal-fermer"
          aria-label="Fermer l'article"
          class="text-slate-400 hover:text-ardoise-950 transition-colors ml-4 shrink-0 p-1 rounded-lg hover:bg-ardoise-50"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Corps -->
      <div class="px-6 sm:px-8 py-8">
        <div id="modal-meta" class="flex items-center gap-3 text-sm text-slate-500 mb-4"></div>
        <h2 id="modal-titre" class="text-2xl sm:text-3xl font-bold text-ardoise-900 mb-8 leading-snug"></h2>
        <div id="modal-contenu" class="article-prose"></div>

        <!-- CTA contact -->
        <div class="mt-10 rounded-2xl bg-ardoise-950 text-white px-6 py-8 text-center">
          <p class="font-bold text-lg mb-1">Votre toiture vous pose des questions ?</p>
          <p class="text-slate-300 text-sm mb-5">Contactez-nous pour un devis gratuit et sans engagement.</p>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 bg-brique-500 hover:bg-brique-600 text-ardoise-950 font-bold px-7 py-3 rounded-full transition-colors"
          >
            Demander un devis gratuit →
          </a>
        </div>

      </div>

    </div>
  </div>
</div>

<script>
  const modal     = document.getElementById('article-modal')!;
  const fond      = document.getElementById('modal-fond')!;
  const fermer    = document.getElementById('modal-fermer')!;
  const elTitre   = document.getElementById('modal-titre')!;
  const elContenu = document.getElementById('modal-contenu')!;
  const elTags    = document.getElementById('modal-tags')!;
  const elMeta    = document.getElementById('modal-meta')!;

  function ouvrirModal(id: string) {
    const source = document.getElementById(`article-body-${id}`);
    const card   = document.querySelector(`[data-open-article="${id}"]`);
    if (!source || !card) return;

    const titre    = card.getAttribute('data-title') ?? '';
    const location = card.getAttribute('data-location') ?? '';
    const dateIso  = card.getAttribute('data-date') ?? '';
    const tags     = JSON.parse(card.getAttribute('data-tags') ?? '[]') as string[];

    elTitre.textContent = titre;
    elContenu.innerHTML = source.innerHTML;

    elTags.innerHTML = tags.map(t =>
      `<span class="bg-ardoise-100 text-ardoise-700 text-xs font-medium px-2.5 py-1 rounded-full">${t}</span>`
    ).join('');

    const dateFormatee = dateIso
      ? new Date(dateIso).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })
      : '';
    elMeta.innerHTML = `<span>📍 ${location}</span><span aria-hidden="true">·</span><time datetime="${dateIso}">${dateFormatee}</time>`;

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    fermer.focus();
  }

  function fermerModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLElement>('[data-open-article]').forEach(el => {
    el.addEventListener('click', () => ouvrirModal(el.getAttribute('data-open-article')!));
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        ouvrirModal(el.getAttribute('data-open-article')!);
      }
    });
  });

  fond.addEventListener('click', fermerModal);
  fermer.addEventListener('click', fermerModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') fermerModal(); });
</script>
