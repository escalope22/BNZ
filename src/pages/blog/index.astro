---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('blog', ({ data }) => !data.draft);
articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function formaterDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<Layout
  titre="Blog — Conseils toiture et zinguerie"
  description="Articles et conseils pratiques sur la toiture, la zinguerie et l'entretien de couverture par BNZ Toitures, artisan couvreur dans l'Ouest de la France."
>

  <div class="pt-24 pb-20 bg-ardoise-50 min-h-screen">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <h1 class="text-4xl font-bold text-ardoise-900 mb-3">Conseils & Actualités</h1>
      <p class="text-slate-600 mb-12 text-lg max-w-2xl">
        Guides pratiques, questions fréquentes et actualités du métier de couvreur-zingueur.
      </p>

      {articles.length === 0 ? (
        <p class="text-slate-500">Aucun article publié pour le moment. Revenez bientôt !</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {articles.map((article) => (
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col">
              <div class="p-6 flex flex-col flex-1">

                <!-- Tags -->
                {article.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-3">
                    {article.data.tags.map((tag) => (
                      <span class="bg-ardoise-100 text-ardoise-700 text-xs font-medium px-2.5 py-1 rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                <h2 class="font-bold text-ardoise-900 text-xl mb-3 leading-snug">
                  {article.data.title}
                </h2>

                <p class="text-slate-600 text-sm mb-4 flex-1 line-clamp-3">
                  {article.data.description}
                </p>

                <div class="flex items-center justify-between text-xs text-slate-500 mt-auto pt-4 border-t border-slate-100">
                  <span>📍 {article.data.location}</span>
                  <time datetime={article.data.pubDate.toISOString()}>
                    {formaterDate(article.data.pubDate)}
                  </time>
                </div>

              </div>
            </article>
          ))}
        </div>
      )}

    </div>
  </div>

</Layout>
